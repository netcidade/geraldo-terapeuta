---
import './admin.css';

interface Props {
  title?: string;
  activePath?: string;
}

const { title = "Dashboard", activePath = "/admin" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Geraldo Luiz Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <style is:global>
        .nav-item {
          display: flex;
          align-items: center;
          gap: 10px;
          padding: 9px 14px;
          cursor: pointer;
          transition: background 0.15s;
          border-left: 3px solid transparent;
          text-decoration: none;
          color: rgba(255, 255, 255, 0.65);
          font-size: 13px;
        }
        .nav-item:hover {
          background: rgba(255, 255, 255, 0.07);
          color: #fff;
        }
        .nav-item.active {
          background: var(--sidebar-active);
          border-left-color: var(--accent);
          color: #fff;
        }
    </style>
  </head>
  <body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <img src="/img/Geraldo-logo.png" alt="Geraldo Luiz" />
        <span>Painel Administrativo</span>
      </div>

      <div class="nav-section-label">Conteúdo</div>
      <a href="/admin" class={`nav-item ${activePath === '/admin' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect></svg>
        Dashboard
      </a>
      <a href="/admin/paginas" class={`nav-item ${activePath === '/admin/paginas' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
        Conteúdo de Páginas
      </a>
      <a href="/admin/especialidades" class={`nav-item ${activePath === '/admin/especialidades' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        Especialidades
      </a>
      <a href="/admin/blog" class={`nav-item ${activePath === '/admin/blog' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
        Blog
      </a>
      <a href="/admin/midia" class={`nav-item ${activePath === '/admin/midia' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
        Galeria de Mídias
      </a>

      <div class="nav-section-label">Configurações Site</div>
      <a href="/admin/layout" class={`nav-item ${activePath === '/admin/layout' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
        Header & Footer
      </a>
      <a href="/admin/seo" class={`nav-item ${activePath === '/admin/seo' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        SEO & Metatags
      </a>
      <a href="/admin/contato" class={`nav-item ${activePath === '/admin/contato' ? 'active' : ''}`}>
        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        Contatos & WhatsApp
      </a>


      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar">N</div>
          <div>
            <div class="user-name">Administrador</div>
            <div class="user-role">geraldoterapeuta.com.br</div>
          </div>
        </div>
        <button class="logout-btn" onclick="doLogout()">Sair da conta</button>
      </div>
    </aside>

    <!-- Main -->
    <div class="main">
      <div class="topbar">
        <span class="topbar-title" id="topbar-title">{title}</span>
        <div class="topbar-right">
          <a href="/" target="_blank" class="view-site-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
            Ver site
          </a>
        </div>
      </div>

      <div class="content">
        <slot />
      </div>
    </div>
    
    <script is:inline>
      async function doLogout() {
        try {
          const res = await fetch("/api/admin/logout", { method: "POST" });
          if (res.ok) window.location.href = "/admin/login";
        } catch (e) {
          alert("Erro ao sair");
        }
      }
      
      function showGlobalToast(msg) {
        let toast = document.getElementById("global-toast");
        if (!toast) {
          toast = document.createElement("div");
          toast.id = "global-toast";
          toast.className = "toast";
          toast.innerHTML = `<span>✔</span> ${msg}`;
          toast.style.position = "fixed";
          toast.style.bottom = "20px";
          toast.style.right = "20px";
          toast.style.zIndex = "9999";
          document.body.appendChild(toast);
        } else {
          toast.innerHTML = `<span>✔</span> ${msg}`;
        }
        toast.classList.remove("show");
        void toast.offsetWidth; 
        toast.classList.add("show");
      }
      window.showGlobalToast = showGlobalToast;
    </script>
  </body>
</html>
