---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppFAB from '../components/layout/WhatsAppFAB.astro';
import SEO from '../components/SEO.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import GoogleTagManager from '../components/GoogleTagManager.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  ogType?: string;
  robots?: string;
  schemaType?: 'ProfessionalService' | 'Service' | 'WebSite' | 'custom';
  customSchema?: Record<string, any>;
}

const {
  title,
  description,
  image,
  canonicalURL,
  ogType,
  robots,
  schemaType = 'ProfessionalService',
  customSchema,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <GoogleTagManager part="head" />
  
  <SEO 
    title={title} 
    description={description} 
    image={image} 
    canonicalURL={canonicalURL} 
    ogType={ogType} 
    robots={robots} 
  />
  
  <SchemaOrg 
    schemaType={schemaType} 
    name={title} 
    description={description} 
    image={image} 
    customSchema={customSchema} 
  />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7GGW83ZJHY"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-7GGW83ZJHY');
  </script>
</head>
<body class="antialiased">
  <GoogleTagManager part="body" />
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <WhatsAppFAB />

  <script>
    // Reveal on scroll
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.15 }
    );
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
