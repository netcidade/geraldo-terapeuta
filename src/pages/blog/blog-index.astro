---
export const prerender = false;
import Layout from '../../components/layout/Layout.astro';
import { getBlogPosts, getEnv } from '../../lib/appwrite';

const env = getEnv(Astro.locals);
const posts = await getBlogPosts(env, 20);
---

<Layout title="Blog do Equilíbrio — Geraldo Luiz Terapeuta" description="Artigos sobre terapia de casal, família e relacionamentos saudáveis.">

  <!-- HERO -->
  <section class="bg-gradient-to-br from-[#EAF6F7] via-white to-white py-20 md:py-24">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 border border-teal/30 text-teal text-[10px] font-body font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full mb-7">
        <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></span>
        Conteúdo e Reflexões
      </div>
      <h1 class="font-display text-4xl md:text-5xl text-navy font-extrabold leading-tight mb-5">
        Blog do <em class="not-italic text-teal">Equilíbrio</em>
      </h1>
      <p class="text-slate-500 font-body text-base max-w-xl mx-auto leading-relaxed">
        Espaço dedicado ao compartilhamento de conhecimentos e vivências sobre a jornada humana e as relações familiares.
      </p>
    </div>
  </section>

  <!-- POSTS -->
  <section class="pb-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <div class="text-5xl mb-4">📝</div>
          <p class="text-slate-400 font-body text-lg">Em breve, novos artigos por aqui!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="group bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden hover:shadow-md hover:-translate-y-1 transition-all duration-300 block">
              <div class="relative h-52 overflow-hidden bg-slate-100">
                {post.image && (
                  <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy"/>
                )}
                {post.category && (
                  <div class="absolute top-3 left-3">
                    <span class="bg-teal text-white text-[9px] font-body font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full">
                      {post.category}
                    </span>
                  </div>
                )}
              </div>
              <div class="p-6">
                <h2 class="font-display font-bold text-navy text-xl leading-tight mb-3 group-hover:text-teal transition-colors">{post.title}</h2>
                <p class="text-slate-500 font-body text-sm leading-relaxed line-clamp-3 mb-5">{post.excerpt}</p>
                <span class="text-teal font-body font-semibold text-sm flex items-center gap-1.5 group-hover:gap-3 transition-all">
                  Ler Artigo Completo
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA WhatsApp -->
  <section class="py-12 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="bg-navy rounded-[2rem] px-10 py-14 text-center">
        <h2 class="font-display text-3xl md:text-4xl text-white font-bold leading-tight mb-3">
          <em class="not-italic">Quer receber novos artigos?</em>
        </h2>
        <p class="text-white/55 font-body text-sm leading-relaxed max-w-md mx-auto mb-8">
          Acompanhe minhas reflexões sobre o bem-estar emocional e receba dicas práticas para o seu dia a dia.
        </p>
        <a href="https://api.whatsapp.com/send?phone=5543988728924" target="_blank" rel="noopener"
           class="inline-flex items-center gap-3 bg-teal text-white font-body font-semibold px-7 py-4 rounded-full hover:bg-teal-600 transition-all hover:shadow-lg">
          Acompanhar via WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
