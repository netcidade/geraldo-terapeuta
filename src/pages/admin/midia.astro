        if (url && url.startsWith("http")) {
          img.src = url;
          img.style.display = "block";
        } else {
          img.style.display = "none";
        }
      };

      window.createProduct = async function () {
        const name = document.getElementById("new-name").value.trim();
        const slug = document.getElementById("new-slug").value.trim();
        const category = document.getElementById("new-category").value;
        if (!name || !slug) return alert("Nome e Slug são obrigatórios.");

        if (productsData.find((p) => p.slug === slug)) {
          return alert(`Já existe uma especialidade com o slug "${slug}".`);
        }

        const newProduct = {
          title: name,
          slug,
          category,
          excerpt: "Resumo da especialidade...",
          content: "Descreva os detalhes deste atendimento aqui...",
          image: "https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png",
          date: new Date().toISOString().split("T")[0],
          seo: { title: "", description: "" },
        };

        const updated = [...productsData, newProduct];

        try {
          const res = await fetch("/api/admin/content", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ file: "products.json", data: updated }),
          });
          const r = await res.json();
          if (r.ok) {
            productsData.push(newProduct);
            window.showSuccess();
            window.closeModal();
            window.renderProductsGrid();
            setTimeout(() => window.editProduct(slug), 500);
          } else {
            alert("Erro ao criar especialidade.");
          }
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };

      window.deleteProduct = async function (slug, name) {
        if (!confirm(`Excluir o produto "${name}" permanentemente?`)) return;
        const p = productsData.find(x => x.slug === slug);
        if (!p || !p.id) {
           return alert("Produto não possui ID. Erro de sincronização.");
        }
        
        try {
          const res = await fetch("/api/admin/products", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: p.id }),
          });
          const r = await res.json();
          if (r.ok) {
            const idx = productsData.findIndex(x => x.slug === slug);
            if (idx > -1) productsData.splice(idx, 1);
            window.renderProductsGrid();
          } else alert("Erro ao excluir.");
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };

