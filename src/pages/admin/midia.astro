      window.openNewProduct = function () {
        const overlay = document.getElementById("modal-overlay");
        overlay.style.display = "flex";
        // Limpa campos
        [
          "new-slug",
          "new-name",
          "new-headline",
          "new-description",
          "new-image",
          "new-features",
        ].forEach((id) => {
          const el = document.getElementById(id);
          if (el) el.value = "";
        });
        document.getElementById("new-img-preview").style.display = "none";
        document.getElementById("new-slug").focus();
        
        sessionStorage.setItem("admin_modal_type", "new_product");
        window.modalInitialState = window.getModalState();
      };

      window.getModalState = function () {
        const type = sessionStorage.getItem("admin_modal_type");
        const state = {};
        if (type === "new_product") {
          ["new-slug", "new-name", "new-headline", "new-description", "new-image"].forEach(id => {
            const el = document.getElementById(id);
            if (el) state[id] = el.value;
          });
        } else if (type === "new_blog") {
          ["new-post-title", "new-post-slug"].forEach(id => {
            const el = document.getElementById(id);
            if (el) state[id] = el.value;
          });
        } else if (type === "edit_specialty") {
          ["prod-name", "prod-category", "prod-excerpt", "prod-img-url"].forEach(id => {
            const el = document.getElementById(id);
            if (el) state[id] = el.value;
          });
          state["content"] = window.getQuillHtml("prod-content");
        } else if (type === "edit_blog") {
          ["post-title", "post-category", "post-excerpt", "post-img-url"].forEach(id => {
            const el = document.getElementById(id);
            if (el) state[id] = el.value;
          });
          state["content"] = window.getQuillHtml("post-content");
        }
        return JSON.stringify(state);
      };

      window.closeModal = function (force = false) {
        if (!force && window.modalInitialState) {
          const currentState = window.getModalState();
          if (currentState !== window.modalInitialState) {
            if (!confirm("Você tem alterações não salvas. Deseja sair mesmo assim?")) return;
          }
        }
        document.getElementById("modal-overlay").style.display = "none";
        document.getElementById("modal-blog-overlay").style.display = "none";
        document.getElementById("modal-edit").classList.remove("active");
        window.modalInitialState = null;
        sessionStorage.removeItem("admin_modal_type");
      };

