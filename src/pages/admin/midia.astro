      window.saveSeo = async function () {
        const page = document.getElementById("seo-page").value;
        const title = document.getElementById("seo-title").value;
        const desc = document.getElementById("seo-description").value;
        const seoData = { title, description: desc };

        if (page === "home" || page === "quem-somos" || page === "contato") {
          const key = page.replace("-", "");
          const payload = {
            file: "pages.json",
            section: key,
            data: { ...pagesData[key], seo: seoData },
          };
          try {
            const res = await fetch("/api/admin/content", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            const r = await res.json();
            if (r.ok) {
              pagesData[payload.section].seo = seoData;
              window.showSuccess();
            } else {
              alert("Erro ao salvar SEO estático: " + (r.error || ""));
            }
          } catch(e) { alert(e.message); }
        } else {
          // If it's a product
          const p = productsData.find(x => x.slug === page);
          if (!p) return alert("Produto não encontrado.");
          
          const payload = { ...p, seo: seoData };
          try {
            const res = await fetch("/api/admin/products", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            const r = await res.json();
            if (r.ok) {
              Object.assign(p, payload);
              window.showSuccess();
            } else {
              alert("Erro ao salvar SEO do produto: " + (r.error || ""));
            }
          } catch(e) { alert(e.message); }
        }
      };

      // Listeners para SEO inputs
      document.addEventListener("DOMContentLoaded", () => {
        const t = document.getElementById("seo-title");
        const d = document.getElementById("seo-description");
        if (t) t.addEventListener("input", window.updateSeoVisuals);
        if (d) d.addEventListener("input", window.updateSeoVisuals);

        // Inicializa primeiro preview
        setTimeout(window.updateSeoPreview, 500);
      });

      // ─── LOGOUT ──────────────────────────────────────────
      window.doLogout = async function () {
        await fetch("/api/admin/logout", { method: "POST" });
        window.location.href = "/admin/login";
      };

      // ─── PAGE SELECTOR ───────────────────────────────────
      window.selectPage = function (key, name) {
        const getNav = (id) =>
          document.querySelector(`[onclick*="showPanel('${id}'"]`);

        if (key === "home") {
          window.showPanel("hero", getNav("hero"));
        } else if (key === "quemsomos") {
          window.showPanel("quemsomos", getNav("quemsomos"));
        } else {
          window.showPanel("products", getNav("products"));
          setTimeout(() => window.editProduct(key), 80);
        }
      };

      window.openSeo = function (page) {
        const getNav = (id) =>
          document.querySelector(`[onclick*="showPanel('${id}'"]`);
        window.showPanel("seo", getNav("seo"));
        const select = document.getElementById("seo-page");
        if (select) {
          select.value = page;
          window.updateSeoPreview();
        }
      };

      // ─── BLOG EDIT & DELETE ────────────────────────────────
      window.editPost = function (slug) {
        const p = blogData.find((x) => x.slug === slug);
        if (!p) return;

        const modal = document.getElementById("modal-edit");
        const body = document.getElementById("modal-edit-body");
        const titleEl = document.getElementById("modal-edit-title");

        titleEl.textContent = `Editando Artigo: ${p.title}`;
        body.innerHTML = `
    <div class="editor-grid">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="field-card">
          <div class="field-label">Título do artigo</div>
          <input class="field-input" id="post-title" value="${p.title}"/>
        </div>
        <div class="field-card">
          <div class="field-label">Categoria</div>
          <select class="field-select" id="post-category">
            <option value="Relacionamentos" ${p.category === "Relacionamentos" ? "selected" : ""}>Relacionamentos</option>
            <option value="Família" ${p.category === "Família" ? "selected" : ""}>Família</option>
            <option value="Bem-estar" ${p.category === "Bem-estar" ? "selected" : ""}>Bem-estar</option>
            <option value="Reflexões" ${p.category === "Reflexões" ? "selected" : ""}>Reflexões</option>
          </select>
        </div>
      </div>

      <div class="field-card">
        <div class="field-label">Resumo (Excerpt)</div>
        <textarea class="field-textarea" id="post-excerpt" rows="2">${p.excerpt || ""}</textarea>
      </div>

      <div class="field-card">
        <div class="field-label">Conteúdo do Artigo <span class="badge-html">WYSIWYG</span></div>
        <div class="ql-wrapper ql-tall" id="ql-wrap-post-content"><div id="ql-post-content"></div></div>
        <div class="html-toggle">
          <button onclick="toggleHtmlMode('post-content')" id="btn-html-post-content">&lt;/&gt; Ver HTML</button>
        </div>
        <textarea class="html-source" id="html-post-content"></textarea>
      </div>

      <div class="field-card">
        <div class="field-label">URL da imagem de destaque <span class="badge-img">IMAGEM</span></div>
        <input class="field-input" id="post-img-url" value="${p.image || ""}" oninput="document.getElementById('post-img-preview').src=this.value"/>
        <img id="post-img-preview" src="${p.image || ""}" alt="" style="margin-top:8px;height:120px;border-radius:8px;border:1px solid #e5e7eb;object-fit:cover; ${p.image ? "" : "display:none"}"/>
      </div>

      <div class="save-row">
        <a href="/blog/${p.slug}" target="_blank" class="btn-preview">Ver artigo no site →</a>
        <div style="display:flex;align-items:center;gap:10px">
          <button class="btn-save" onclick="savePost('${p.slug}')">Salvar Artigo</button>
        </div>
      </div>
    </div>`;

        modal.classList.add("active");

        setTimeout(() => {
          delete quills["post-content"];
          createQuill("post-content", TOOLBAR_FULL, p.content || "");
        }, 60);

        sessionStorage.setItem("admin_modal_type", "edit_blog");
        sessionStorage.setItem("admin_modal_id", slug);
        setTimeout(() => {
          window.modalInitialState = window.getModalState();
        }, 300);
      };

      window.savePost = async function (slug) {
        const title = document.getElementById("post-title")?.value ?? "";
        const category = document.getElementById("post-category")?.value ?? "";
        const excerpt = document.getElementById("post-excerpt")?.value ?? "";
        const htmlContent = window.getQuillHtml("post-content");
        const image = document.getElementById("post-img-url")?.value ?? "";

        const existing = blogData.find(p => p.slug === slug);
        const payload = { slug, title, category, excerpt, content: htmlContent, image };
        if (existing && existing.id) payload.id = existing.id;

        try {
          const res = await fetch("/api/admin/blog", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const r = await res.json();
          if (r.ok) {
            const idx = blogData.findIndex((p) => p.slug === slug);
            if (idx > -1) Object.assign(blogData[idx], payload);
            window.showSuccess();
            window.modalInitialState = window.getModalState();
          } else alert("Erro ao salvar artigo.");
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };

      window.deletePost = async function (slug, title) {
        if (!confirm(`Excluir o post "${title}" permanentemente?`)) return;
        const p = blogData.find(x => x.slug === slug);
        if (!p || !p.id) return alert("Artigo não possui ID.");
        
        try {
          const res = await fetch("/api/admin/blog", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: p.id }),
          });
          const r = await res.json();
          if (r.ok) {
            const idx = blogData.findIndex(x => x.slug === slug);
            if (idx > -1) blogData.splice(idx, 1);
            window.renderBlogGrid();
          } else alert("Erro ao excluir.");
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };
    </script>
</AdminLayout>
