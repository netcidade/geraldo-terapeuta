---
export const prerender = false;
import { getDatabases, getEnvIds } from "../../lib/appwrite";
import { Query } from "node-appwrite";
import AdminLayout from "../../layouts/AdminLayout.astro";

const env = Astro.locals;
const { DB_ID, COL_CONTENT, COL_PRODUCTS, COL_BLOG } = getEnvIds(env);
const db = getDatabases(env);

let content = {};
let products = [];
let blogData = [];

try {
  const pagesRes = await db.listDocuments(DB_ID, COL_CONTENT, [Query.equal("key", "pages")]);
  const pagesDoc = pagesRes.documents[0];
  content = pagesDoc ? JSON.parse(pagesDoc.data) : {};

  const productsRes = await db.listDocuments(DB_ID, COL_PRODUCTS, [Query.limit(100)]);
  products = productsRes.documents.map((d) => JSON.parse(d.data));

  const blogRes = await db.listDocuments(DB_ID, COL_BLOG, [Query.limit(100)]);
  blogData = blogRes.documents.map((d) => JSON.parse(d.data));
} catch (e) {
  console.warn("Erro Appwrite:", e);
}
---

<AdminLayout title="Galeria de Mídia" activePath="/admin/midia">
  <div class="panel active" id="panel-media">
          <div class="section-heading">Gerenciador de mídias</div>
          <div
            class="img-drop"
            onclick="document.getElementById('media-file').click()"
            ondragover="dragOver(event,'media-drop-main')"
            ondragleave="dragLeave('media-drop-main')"
            ondrop="dropFile(event,'media-drop-main','media-grid-previews')"
          >
            <div class="img-drop-icon">📁</div>
            <div class="img-drop-text">
              Arraste imagens ou clique para fazer upload
            </div>
            <div class="img-drop-sub">
              PNG, JPG, WebP, SVG — múltiplos arquivos aceitos
            </div>
          </div>
          <input
            type="file"
            id="media-file"
            accept="image/*"
            multiple
            style=""
            onchange="previewMultiple(this,'media-grid-previews')"
          />
          <div class="media-grid" id="media-grid-previews"></div>
        </div>

  <div class="modal-overlay" id="modal-success" onclick="closeModal('modal-success')">
    <div class="modal-content" style="max-width: 400px" onclick="event.stopPropagation()">
      <div class="success-card">
        <div class="success-icon">🎉</div>
        <div class="success-title">Pronto!</div>
        <div class="success-text" id="modal-success-text">Alterações salvas com sucesso.</div>
        <div class="success-actions">
          <button class="btn-save" onclick="closeModal('modal-success')">Continuar</button>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ productsData: products, blogData: blogData, pagesData: content }}>
      // ─── TOOLBAR COMPLETA ────────────────────────────────
      const TOOLBAR_FULL = [
        [{ header: [1, 2, 3, false] }],
        ["bold", "italic", "underline", "strike"],
        [{ color: [] }, { background: [] }],
        [{ list: "ordered" }, { list: "bullet" }],
        [{ align: [] }],
        ["link"],
        ["clean"],
      ];

      // Injeta mocks se estiver vazio para facilitar o início
      if (blogData.length === 0) {
        const mocks = [
          {
            title: "Como a Terapia Sistêmica pode transformar sua Família",
            slug: "terapia-sistemica-familia",
            excerpt: "Entenda como olhar para as relações como um todo pode trazer equilíbrio e harmonia para o lar.",
            date: "02 Abr, 2024",
            image: "/img/terapia-casais2_600x450.jpg",
            category: "Família",
            content: `<p>A Terapia Sistêmica é uma abordagem profunda que olha para além do indivíduo. Ela compreende que somos parte de um sistema vivo — a nossa família — onde cada ação e reação reverbera em todos os membros.</p><h2>O que é o Olhar Sistêmico?</h2><p>Imagine uma teia onde cada fio está conectado. Quando um fio é tocado, toda a teia vibra. Na família, não é diferente. Muitas vezes, o comportamento de um membro é um reflexo de dinâmicas invisíveis que vêm de gerações passadas.</p><blockquote>"Na terapia sistêmica, não buscamos culpados, mas sim padrões que podem ser transformados para o bem de todos."</blockquote><h2>Os benefícios para o Lar</h2><p>Ao identificarmos esses padrões, conseguimos abrir espaço para uma comunicação mais clara, empática e, acima de tudo, libertadora. O resultado é um lar onde o equilíbrio e o amor florescem com maturidade.</p>`
          },
          {
            title: "5 Sinais de que é hora de buscar Terapia de Casal",
            slug: "sinais-terapia-casal",
            excerpt: "Identificar o momento certo para buscar ajuda profissional pode ser o diferencial para o futuro da relação.",
            date: "28 Mar, 2024",
            image: "/img/namorados-noivos2_600x450.jpg",
            category: "Relacionamentos",
            content: `<p>Muitos casais esperam chegar ao limite para buscar ajuda. No entanto, a terapia de casal é uma ferramenta poderosa de prevenção e fortalecimento de laços.</p><h2>Sinais de Alerta</h2><p>Abaixo, listo 5 sinais claros de que o casal pode se beneficiar de um acompanhamento profissional:</p><ul><li>Falta de diálogo ou discussões repetitivas pelos mesmos motivos.</li><li>Perda de intimidade e conexão emocional.</li><li>Desconfiança persistente ou mágoas do passado não resolvidas.</li><li>Sensação de que "andam em ovos" um com o outro.</li><li>Dificuldade em planejar o futuro em conjunto.</li></ul><p>O acompanhamento terapêutico oferece as ferramentas necessárias para reconstruir a ponte do diálogo e da confiança.</p>`
          },
          {
            title: "Equilíbrio emocional na vida madura: Novos horizontes",
            slug: "equilibrio-vida-madura",
            excerpt: "A fase do ninho vazio e as mudanças da maturidade podem ser uma oportunidade de reencontro para o casal.",
            date: "20 Mar, 2024",
            image: "/img/vidamadura2_600x450.jpg",
            category: "Bem-estar",
            content: `<p>A maturidade traz consigo grandes transformações. Quando os filhos saem de casa (o chamado 'ninho vazio'), o casal se depara com um novo cenário: o reencontro consigo mesmos e com o parceiro.</p><h2>Oportunidade de Reencontro</h2><p>Esta fase não precisa ser de solidão, mas sim de renovação. É o momento de redescobrir hobbies, planos de viagem e, principalmente, fortalecer a cumplicidade que foi a base da família por tantos anos.</p><p>A terapia nesta fase foca na ressignificação de objetivos e no acolhimento das novas emoções que surgem com o passar dos anos.</p>`
          }
        ];
        mocks.forEach(m => blogData.push(m));
      }

      const TOOLBAR_SIMPLE = [
        ["bold", "italic", "underline"],
        [{ color: [] }],
        ["link", "clean"],
      ];

      // Mapa de instâncias Quill: id → Quill instance
      const quills = {};

      // ─── CRIA EDITOR QUILL ───────────────────────────────
      function createQuill(id, toolbar, initialHtml) {
        const el = document.getElementById("ql-" + id);
        if (!el || quills[id]) return;
        const q = new Quill(el, {
          theme: "snow",
          modules: { toolbar },
          placeholder: "Digite aqui...",
        });
        if (initialHtml) q.clipboard.dangerouslyPasteHTML(initialHtml);
        quills[id] = q;
        // Sincroniza textarea de código ao digitar
        q.on("text-change", () => {
          const ta = document.getElementById("html-" + id);
          if (ta && !ta.classList.contains("visible")) return;
          if (ta) ta.value = q.getSemanticHTML();
        });
        return q;
      }

      // ─── TOGGLE MODO HTML ────────────────────────────────
      window.toggleHtmlMode = function (id) {
        const ta = document.getElementById("html-" + id);
        const btn = document.getElementById("btn-html-" + id);
        const q = quills[id];
        if (!ta || !q) return;

        if (ta.classList.contains("visible")) {
          // Volta pro WYSIWYG — aplica o HTML editado
          q.clipboard.dangerouslyPasteHTML(ta.value);
          ta.classList.remove("visible");
          btn.classList.remove("active");
          btn.textContent = "</> Ver HTML";
        } else {
          // Mostra HTML
          ta.value = q.getSemanticHTML();
          ta.classList.add("visible");
          btn.classList.add("active");
          btn.textContent = "↩ Voltar WYSIWYG";
          ta.style.minHeight = "120px";
          // Se editar no textarea, sincroniza ao sair
          ta.oninput = () => {}; // live não — só ao voltar
        }
      };

      // ─── PEGA HTML DO QUILL ──────────────────────────────
      window.getQuillHtml = function (id) {
        const ta = document.getElementById("html-" + id);
        // Se estiver no modo código, usa o textarea
        if (ta && ta.classList.contains("visible")) return ta.value;
        return quills[id] ? quills[id].getSemanticHTML() : "";
      };

      // ─── INICIALIZA QUILLS ESTÁTICOS ─────────────────────
      document.addEventListener("DOMContentLoaded", () => {
        const h = pagesData.home || {};
        createQuill(
          "headline",
          TOOLBAR_SIMPLE,
          h.hero?.headline || "Sua <strong>identidade</strong><br>começa aqui.",
        );
        createQuill(
          "subheadline",
          TOOLBAR_SIMPLE,
          h.hero?.subheadline ||
            "Crachás, cordões e pulseiras. <strong>Mais de 25 anos</strong> em Londrina/PR.",
        );
        createQuill(
          "endereco",
          TOOLBAR_SIMPLE,
          pagesData.contato?.endereco ||
            "Rua Eduardo Benjamin Hosken, 200<br>CEP: 86020-440 — Londrina/PR",
        );
        createQuill(
          "qs-headline",
          TOOLBAR_SIMPLE,
          pagesData.quemsomos?.hero_headline ||
            "25 anos identificando <strong>pessoas e marcas</strong>.",
        );
        createQuill(
          "qs-about",
          TOOLBAR_FULL,
          pagesData.quemsomos?.about_text ||
            "<p>O <strong>Geraldo Luiz</strong> é um terapeuta com mais de 20 anos de experiência.</p>",
        );

        // Restaura o estado da UI após HMR
        setTimeout(() => {
          const act = sessionStorage.getItem("admin_active_panel");
          if (
            act &&
            document.getElementById("panel-" + act) &&
            !["hero", "seo", "contato", "quemsomos"].includes(act)
          ) {
            window.showPanel(act);
          } else {
            // Se não há painel restaurado, força o painel de mídia nesta página
            window.showPanel("media");
          }
          const modalType = sessionStorage.getItem("admin_modal_type");
          const modalId = sessionStorage.getItem("admin_modal_id");

          if ((modalType === "edit_product" || modalType === "edit_specialty") && modalId) {
            window.showPanel("products");
            setTimeout(() => window.editProduct(modalId), 50);
          } else if (modalType === "edit_post" && modalId) {
            window.showPanel("blog");
            setTimeout(() => window.editPost(modalId), 50);
          } else if (modalType === "edit_page" && modalId) {
            window.selectPage(modalId);
          }

          if (sessionStorage.getItem("admin_show_success") === "true") {
            sessionStorage.removeItem("admin_show_success");
            window.showSuccess();
          }
        }, 100);
      });

      // ─── PAINEL NAVIGATION ───────────────────────────────
      window.showPanel = function (id, el) {
        const titles = {
          dashboard: "Dashboard",
          header: "Header — Navegação",
          pages: "Páginas",
          hero: "Hero / Banner",
          products: "Especialidades",
          blog: "Blog do Equilíbrio",
          media: "Mídias",
          footer: "Footer — Rodapé",
          seo: "SEO",
          contato: "Contato",
          quemsomos: "Quem Somos",
          layout: "Layout",
          pills: "Menu de Atalhos (Pills)",
        };

        // Paineis que abrem em modal
        const isEdit = [
          "hero",
          "seo",
          "contato",
          "quemsomos",
          "header",
          "footer",
          "layout",
        ].includes(id);

        if (isEdit) {
          window.openEditModal(id, titles[id]);
          return;
        }

        document
          .querySelectorAll(".panel")
          .forEach((p) => p.classList.remove("active"));
        document
          .querySelectorAll(".nav-item")
          .forEach((n) => n.classList.remove("active"));

        const target = document.getElementById("panel-" + id);
        if (target) target.classList.add("active");
        if (el) el.classList.add("active");

        document.getElementById("topbar-title").textContent = titles[id] || id;
        if (id === "products") window.renderProductsGrid();
        if (id === "blog") window.renderBlogGrid();
        if (id === "media") window.renderMediaGrid();
        if (id === "header") window.loadHeaderPanel();
        if (id === "footer") window.loadFooterPanel();
        if (id === "layout") window.loadHeaderPanel(); // compat
        if (id === "pills") window.renderPills();

        sessionStorage.setItem("admin_active_panel", id);
      };

      // ─── MODAL EDIT HELPERS ──────────────────────────────
      window.openEditModal = function (id, title) {
        const modal = document.getElementById("modal-edit");
        const body = document.getElementById("modal-edit-body");
        const titleEl = document.getElementById("modal-edit-title");

        titleEl.textContent = title;

        // Move o painel para dentro do modal
        const panel = document.getElementById("panel-" + id);
        if (panel) {
          body.innerHTML = "";
          body.appendChild(panel);
          panel.classList.add("active");
          modal.classList.add("active");

          // Ajustes específicos por seção
          if (id === "seo") window.updateSeoPreview();
        }

        sessionStorage.setItem("admin_modal_type", "edit_page");
        sessionStorage.setItem("admin_modal_id", id);
      };

      window.closeEditModal = function () {
        const modal = document.getElementById("modal-edit");
        const body = document.getElementById("modal-edit-body");

        // Devolve o painel para o content original apenas se for um ".panel" fixo
        const panel = body.firstElementChild;
        if (panel && panel.classList.contains("panel")) {
          document.querySelector(".content").appendChild(panel);
          panel.classList.remove("active");
        } else {
          // Se for conteúdo dinâmico (ex: editor de produto), apenas limpa
          body.innerHTML = "";
        }

        modal.classList.remove("active");
        sessionStorage.removeItem("admin_modal_type");
        sessionStorage.removeItem("admin_modal_id");
      };

      window.showSuccess = function () {
        document.getElementById("modal-success").classList.add("active");
        sessionStorage.setItem("admin_show_success", "true");
      };

      window.closeSuccessModal = function () {
        document.getElementById("modal-success").classList.remove("active");
        sessionStorage.removeItem("admin_show_success");
      };

      window.continueEditing = function () {
        window.closeSuccessModal();
      };

      window.backToDashboard = function () {
        window.closeSuccessModal();
        window.closeEditModal();
        window.showPanel(
          "dashboard",
          document.querySelector('[onclick*="dashboard"]'),
        );
      };

      // ─── LAYOUT: HEADER ──────────────────────────────────
      window.loadLayoutPanel = function () {
        window.loadHeaderPanel();
      }; // compat

      window.loadHeaderPanel = function () {
        const lay = pagesData.layout || {};
        const hdr = lay.header || {};
        const cnt = pagesData.contato || {};
        const set = (id, val) => {
          const el = document.getElementById(id);
          if (el) el.value = val || "";
        };
        set(
          "layout-logo",
          hdr.logo_url ||
            lay.logo_url ||
            "https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png",
        );
        set("layout-phone1", hdr.phone1 || cnt.telefone1 || "(43) 3026-1326");
        set("layout-phone2", hdr.phone2 || cnt.telefone2 || "(43) 3323-3692");
        set("layout-whatsapp", hdr.whatsapp || cnt.whatsapp || "5543988179234");
        set("layout-cta-text", hdr.cta_text || "Orçamento →");
        set(
          "layout-cta-url",
          hdr.cta_url ||
            "https://api.whatsapp.com/send?phone=" +
              (cnt.whatsapp || "5543988179234"),
        );
        const logoIn = document.getElementById("layout-logo");
        const logoPv = document.getElementById("layout-logo-preview");
        if (logoIn && logoPv) {
          logoPv.src = logoIn.value;
          logoPv.style.display = "block";
          logoIn.oninput = () => {
            logoPv.src = logoIn.value;
          };
        }
      };

      // ─── LAYOUT: FOOTER ──────────────────────────────────
      window.loadFooterPanel = function () {
        const lay = pagesData.layout || {};
        const ftr = lay.footer || {};
        const hdr = lay.header || {};
        const cnt = pagesData.contato || {};
        const set = (id, val) => {
          const el = document.getElementById(id);
          if (el) el.value = val || "";
        };
        set(
          "layout-footer-logo",
          ftr.logo_url ||
            hdr.logo_url ||
            "https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png",
        );
        set(
          "layout-footer-desc",
          ftr.desc ||
            lay.footer_desc ||
            "Sistema de identificação com mais de 25 anos de experiência. Qualidade e inovação em Londrina/PR.",
        );

        set(
          "layout-copyright",
          ftr.copyright ||
            lay.copyright ||
            "© " +
              new Date().getFullYear() +
              " Geraldo Luiz — Todos os direitos reservados.",
        );
        const fLogoIn = document.getElementById("layout-footer-logo");
        const fLogoPv = document.getElementById("layout-footer-logo-preview");
        if (fLogoIn && fLogoPv) {
          fLogoPv.src = fLogoIn.value;
          fLogoPv.style.display = "block";
          fLogoIn.oninput = () => {
            fLogoPv.src = fLogoIn.value;
          };
        }
      };

      // Salva apenas o Header
      window.saveHeader = async function () {
        const get = (id) => document.getElementById(id)?.value?.trim() || "";
        const current = pagesData.layout || {};
        const updated = {
          ...current,
          header: {
            logo_url: get("layout-logo"),
            phone1: get("layout-phone1"),
            phone2: get("layout-phone2"),
            whatsapp: get("layout-whatsapp"),
            cta_text: get("layout-cta-text"),
            cta_url: get("layout-cta-url"),
          },
        };
        try {
          const res = await fetch("/api/admin/content", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              file: "pages.json",
              section: "layout",
              data: updated,
            }),
          });
          const r = await res.json();
          if (r.ok) {
            pagesData.layout = updated;
            window.showSuccess();
          } else alert("Erro ao salvar header: " + r.error);
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };

      // Salva apenas o Footer
      window.saveFooter = async function () {
        const get = (id) => document.getElementById(id)?.value?.trim() || "";
        const current = pagesData.layout || {};
        const updated = {
          ...current,
          footer: {
            logo_url: get("layout-footer-logo"),
            desc: get("layout-footer-desc"),

            copyright: get("layout-copyright"),
          },
        };
        try {
          const res = await fetch("/api/admin/content", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              file: "pages.json",
              section: "layout",
              data: updated,
            }),
          });
          const r = await res.json();
          if (r.ok) {
            pagesData.layout = updated;
            window.showSuccess();
          } else alert("Erro ao salvar footer: " + r.error);
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };

      // ─── MEDIA GERENCIADOR ───────────────────────────────
      window.dragOver = (e, id) => {
        e.preventDefault();
        document.getElementById(id)?.classList.add("dragover");
      };
      window.dragLeave = (id) =>
        document.getElementById(id)?.classList.remove("dragover");

      window.dropFile = (e, dropId) => {
        e.preventDefault();
        document.getElementById(dropId)?.classList.remove("dragover");
        if (e.dataTransfer.files.length)
          window.uploadFiles(e.dataTransfer.files);
      };

      window.previewMultiple = (input) => {
        if (input.files.length) window.uploadFiles(input.files);
        input.value = ""; // reseta o input para permitir enviar a mesma imagem de novo se quiser
      };

      window.previewFile = (input, previewId, urlInputId) => {
        if (!input.files.length) return;
        const url = URL.createObjectURL(input.files[0]);
        document.getElementById(previewId).innerHTML =
          `<div class="img-preview-item"><img src="${url}" alt=""/></div>`;
        if (urlInputId) document.getElementById(urlInputId).value = url;
      };

      window.uploadFiles = async function (files) {
        const grid = document.getElementById("media-grid-previews");
        // Optional loading state text
        const originalHtml = grid.innerHTML;

        for (let file of Array.from(files)) {
          if (!file.type.startsWith("image/")) continue;
          const formData = new FormData();
          formData.append("file", file);
          try {
            const res = await fetch("/api/admin/media", {
              method: "POST",
              body: formData,
            });
            const r = await res.json();
            if (!r.ok) {
              alert("Erro ao enviar " + file.name + ": " + r.error);
            }
          } catch (e) {
            alert("Erro de conexão: " + e.message);
          }
        }

        // Reload full grid after all uploads finish
        window.renderMediaGrid();
      };

      window.deleteMedia = async function (id) {
        if (
          !confirm(
            `Tem certeza que deseja excluir esta imagem? Essa ação apagará a foto permanentemente do servidor.`,
          )
        )
          return;
        try {
          const res = await fetch("/api/admin/media", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
          });
          const r = await res.json();
          if (r.ok) {
            window.renderMediaGrid();
          } else {
            alert("Erro ao excluir: " + r.error);
          }
        } catch (e) {
          alert("Erro: " + e.message);
        }
      };

      window.copyUrl = function (url, btn) {
        navigator.clipboard.writeText(url).then(() => {
          const old = btn.textContent;
          btn.textContent = "Copiado!";
          btn.style.background = "#d1fae5";
          btn.style.color = "#065f46";
          setTimeout(() => {
            btn.textContent = old;
            btn.style.background = "";
            btn.style.color = "";
          }, 1500);
        });
      };

      window.renderMediaGrid = async function () {
        const grid = document.getElementById("media-grid-previews");
        if (!grid) return;

        grid.innerHTML =
          '<div style="color:var(--text-muted);font-size:12px;padding:1rem;">Carregando mídias...</div>';

        try {
          const res = await fetch("/api/admin/media");
          const r = await res.json();
          if (r.ok) {
            grid.innerHTML = "";
            if (r.media.length === 0) {
              grid.innerHTML =
                '<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#9ca3af;font-size:13px;background:#f8fafc;border-radius:12px;border:1px dashed var(--border)">Nenhuma imagem enviada ainda. Faça upload acima.</div>';
            }
            r.media.forEach((img) => {
              const relativeUrl = img.url;
              const card = document.createElement("div");
              card.className = "media-card";
              card.innerHTML = `
          <img class="media-card-img" src="${img.url}" loading="lazy" alt="${img.name}" />
          <div class="media-card-body">
            <div class="media-card-name" title="${img.name}">${img.name}</div>
            <div class="media-card-url-row">
              <input class="media-card-input" readonly value="${relativeUrl}" onclick="this.select()"/>
              <button class="media-card-btn-copy" onclick="copyUrl('${relativeUrl}', this)">Copiar</button>
            </div>
            <button class="media-card-btn-delete" onclick="deleteMedia('${img.id}')">Excluir</button>
          </div>
        `;
              grid.appendChild(card);
            });
          } else {
            grid.innerHTML =
              '<div style="color:red;font-size:12px">Erro: ' +
              r.error +
              "</div>";
          }
        } catch (e) {
