        if (page === "home" || page === "quem-somos" || page === "contato") {
          const key = page.replace("-", "");
          data = pagesData[key]?.seo;
        } else {
          data = productsData.find((p) => p.slug === page)?.seo;
        }

        const title = data?.title || "";
        const desc = data?.description || "";

        document.getElementById("seo-title").value = title;
        document.getElementById("seo-description").value = desc;

        window.updateSeoVisuals();
