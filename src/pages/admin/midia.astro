        const desc = document.getElementById("seo-description").value;
        const page = document.getElementById("seo-page").value;

        // Counts
        document.getElementById("seo-title-count").textContent =
          `${title.length} / 60 caracteres`;
        document.getElementById("seo-desc-count").textContent =
          `${desc.length} / 160 caracteres`;

