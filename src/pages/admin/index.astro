---
export const prerender = false;
import { getDatabases, getEnvIds } from "../../lib/appwrite";
import { Query } from "node-appwrite";
import AdminLayout from "../../layouts/AdminLayout.astro";

const env = Astro.locals;
const { DB_ID, COL_CONTENT, COL_PRODUCTS, COL_BLOG } = getEnvIds(env);
const db = getDatabases(env);

let errorMsg = null;
let pagesCount = 0;
let productsCount = 0;
let blogCount = 0;
let productsData: any[] = [];

try {
  const pagesRes = await db.listDocuments(DB_ID, COL_CONTENT, [Query.equal("key", "pages")]);
  const doc = pagesRes.documents[0];
  const content = doc ? JSON.parse(doc.data) : {};
  pagesCount = Object.keys(content).length > 0 ? Object.keys(content).length : 5;

  const productsRes = await db.listDocuments(DB_ID, COL_PRODUCTS, [Query.limit(100)]);
  productsCount = productsRes.total;
  productsData = productsRes.documents.map((d: any) => JSON.parse(d.data));

  const blogRes = await db.listDocuments(DB_ID, COL_BLOG, [Query.limit(1)]);
  blogCount = blogRes.total;
  
  if (!DB_ID || !COL_PRODUCTS) {
    errorMsg = "Configurações de ambiente incompletas (.env).";
  }
} catch (e: any) {
  console.warn("Erro ao buscar contagens:", e);
  errorMsg = "Falha ao conectar com Appwrite: " + e.message;
}
---

<AdminLayout title="Dashboard" activePath="/admin">
  {errorMsg && (
    <div style="background: #fee2e2; color: #991b1b; padding: 1.5rem; border-radius: 12px; border: 1px solid #fecaca; margin-bottom: 2rem; font-size: 14px;">
      <div style="font-weight: bold; margin-bottom: 4px;">⚠️ Erro de Carregamento</div>
      <div>{errorMsg}</div>
      <div style="margin-top: 8px; font-size: 12px; opacity: 0.8;">Verifique o arquivo .env e a conexão com o banco de dados.</div>
    </div>
  )}
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon">📄</div>
      <div class="metric-value">{pagesCount}</div>
      <div class="metric-label">Configurações Estáticas</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">🏷️</div>
      <div class="metric-value">{productsCount}</div>
      <div class="metric-label">Especialidades</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon">📖</div>
      <div class="metric-value">{blogCount}</div>
      <div class="metric-label">Posts no Blog</div>
    </div>
  </div>

  <div class="section-heading">Acesso rápido — Estruturas do Site</div>
  <div class="pages-list">
    {
      [
        { name: "Páginas Fixas (Home, Sobre, SEO)", action: "/admin/paginas", icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" },
        { name: "Especialidades Terapêuticas", action: "/admin/especialidades", icon: "M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" },
        { name: "Blog de Artigos", action: "/admin/blog", icon: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20" },
        { name: "Galeria de Mídias/Imagens", action: "/admin/midia", icon: "M3 3h18v18H3z" },
      ].map((p) => (
        <div class="page-row">
          <div class="page-info">
            <div class="page-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={p.icon} />
              </svg>
            </div>
            <div>
              <div class="page-name">{p.name}</div>
              <div class="page-slug">{p.action}</div>
            </div>
          </div>
          <div class="page-actions">
            <a href={p.action} class="btn-edit" style="text-decoration:none">
              Acessar
            </a>
          </div>
        </div>
      ))
    }
  </div>
</AdminLayout>
