---
export const prerender = false;
import '@/styles/global.css';S
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Novo Post — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #f4f5f7; color: #1f2937; padding: 2rem; }
    .container { max-width: 820px; margin: 0 auto; }
    .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
    .back { display: flex; align-items: center; gap: 6px; color: #0E9AA7; text-decoration: none; font-size: 13px; }
    .back:hover { text-decoration: underline; }
    h1 { font-family: 'Playfair Display', serif; font-size: 24px; color: #0B3954; }
    .card { background: #fff; border-radius: 16px; border: 1px solid #e5e7eb; padding: 1.5rem; margin-bottom: 1rem; }
    .fl { font-size: 10px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 7px; }
    .fi { width: 100%; border: 1.5px solid #e5e7eb; border-radius: 10px; padding: 10px 14px; font-size: 14px; font-family: 'DM Sans', sans-serif; outline: none; transition: border-color 0.15s; }
    .fi:focus { border-color: #0E9AA7; box-shadow: 0 0 0 3px rgba(14,154,167,0.08); }
    .g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .ql-wrapper { border: 1.5px solid #e5e7eb; border-radius: 10px; overflow: hidden; }
    .ql-wrapper:focus-within { border-color: #0E9AA7; }
    .ql-wrapper .ql-toolbar { border: none; border-bottom: 1px solid #e5e7eb; background: #f8fafc; }
    .ql-wrapper .ql-container { border: none; font-family: 'DM Sans', sans-serif; }
    .ql-wrapper .ql-editor { min-height: 300px; padding: 14px 16px; font-size: 15px; line-height: 1.8; }
    .btn-save { background: #0E9AA7; color: #fff; border: none; border-radius: 50px; padding: 12px 28px; font-size: 14px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background 0.15s; }
    .btn-save:hover { background: #0b7d89; }
    .btn-draft { background: #f4f5f7; color: #4A5568; border: 1.5px solid #e5e7eb; border-radius: 50px; padding: 12px 28px; font-size: 14px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
    .btn-draft:hover { border-color: #0B3954; color: #0B3954; }
    .check-wrap { display: flex; align-items: center; gap: 8px; }
    .check-wrap input { width: 16px; height: 16px; accent-color: #0E9AA7; cursor: pointer; }
    .check-wrap label { font-size: 13px; color: #4A5568; cursor: pointer; }
    #toast { display: none; position: fixed; bottom: 2rem; right: 2rem; background: #0B3954; color: #fff; padding: 12px 20px; border-radius: 12px; font-size: 13px; z-index: 999; }
    #toast.show { display: block; animation: slideUp .3s ease; }
    @keyframes slideUp { from { opacity:0; transform:translateY(10px) } to { opacity:1; transform:translateY(0) } }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div>
        <a href="/admin" class="back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Voltar ao painel
        </a>
        <h1 style="margin-top:8px">Novo post do Blog</h1>
      </div>
      <div style="display:flex;gap:10px">
        <button class="btn-draft" onclick="savePost(false)">Salvar rascunho</button>
        <button class="btn-save" onclick="savePost(true)">Publicar →</button>
      </div>
    </div>

    <div class="card">
      <div class="fl">Título do post *</div>
      <input class="fi" id="post-title" placeholder="Ex: Como superar conflitos no casamento" oninput="autoSlug(this.value)"/>
    </div>

    <div class="card g2">
      <div>
        <div class="fl">Slug (URL) *</div>
        <input class="fi" id="post-slug" placeholder="como-superar-conflitos-no-casamento"/>
      </div>
      <div>
        <div class="fl">Categoria</div>
        <input class="fi" id="post-category" placeholder="Ex: Terapia de Casal"/>
      </div>
    </div>

    <div class="card">
      <div class="fl">Resumo / Excerpt</div>
      <textarea class="fi" id="post-excerpt" rows="3" placeholder="Breve descrição do post para SEO e listagem do blog..." style="resize:vertical;line-height:1.6"></textarea>
    </div>

    <div class="card">
      <div class="fl">URL da imagem de capa</div>
      <input class="fi" id="post-image" placeholder="https://..." oninput="previewCover(this.value)"/>
      <img id="cover-preview" src="" alt="" style="margin-top:10px;height:140px;border-radius:10px;object-fit:cover;display:none;border:1px solid #e5e7eb"/>
    </div>

    <div class="card">
      <div class="fl">Conteúdo do post *</div>
      <div class="ql-wrapper">
        <div id="editor"></div>
      </div>
    </div>

    <div class="card" style="display:flex;align-items:center;justify-content:space-between">
      <div class="check-wrap">
        <input type="checkbox" id="published" checked/>
        <label for="published">Publicar imediatamente</label>
      </div>
      <div style="display:flex;gap:10px">
        <button class="btn-draft" onclick="savePost(false)">Salvar rascunho</button>
        <button class="btn-save" onclick="savePost(true)">Publicar →</button>
      </div>
    </div>
  </div>

  <div id="toast"></div>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
  <script>
    const quill = new Quill('#editor', {
      theme: 'snow',
      placeholder: 'Escreva seu artigo aqui...',
      modules: {
        toolbar: [
          [{ header: [1,2,3,false] }],
          ['bold','italic','underline'],
          [{ color:[] }],
          [{ list:'ordered' },{ list:'bullet' }],
          ['link','blockquote'],
          ['clean'],
        ]
      }
    });

    function autoSlug(title) {
      const slug = title
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
        .replace(/[^a-z0-9\s-]/g,'')
        .trim().replace(/\s+/g,'-');
      document.getElementById('post-slug').value = slug;
    }

    function previewCover(url) {
      const img = document.getElementById('cover-preview');
      if (url.startsWith('http')) { img.src = url; img.style.display = 'block'; }
      else img.style.display = 'none';
    }

    function toast(msg) {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.classList.add('show');
      setTimeout(() => el.classList.remove('show'), 2500);
    }

    async function savePost(publish) {
      const title   = document.getElementById('post-title').value.trim();
      const slug    = document.getElementById('post-slug').value.trim();
      if (!title || !slug) { alert('Título e slug são obrigatórios.'); return; }

      const post = {
        title,
        slug,
        category: document.getElementById('post-category').value.trim(),
        excerpt:  document.getElementById('post-excerpt').value.trim(),
        image:    document.getElementById('post-image').value.trim(),
        content:  quill.getSemanticHTML(),
        published: publish || document.getElementById('published').checked,
      };

      const res = await fetch('/api/admin/blog', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(post),
      });
      const r = await res.json();
      if (r.ok) {
        toast(publish ? '✅ Post publicado!' : '✅ Rascunho salvo!');
        setTimeout(() => location.href = '/admin', 1500);
      } else {
        alert('Erro: ' + r.error);
      }
    }
  </script>
</body>
</html>
