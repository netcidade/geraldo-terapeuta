---
export const prerender = false;
const env = Astro.locals;
const ENV_TOKEN = env.ADMIN_TOKEN ?? import.meta.env.ADMIN_TOKEN ?? 'NÃO_LIDO_DO_ENV';
const TOKEN_FALLBACK = 'geraldo2025';

const finalToken = (ENV_TOKEN !== 'NÃO_LIDO_DO_ENV') ? ENV_TOKEN : TOKEN_FALLBACK;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Admin - Diagnóstico de Autenticação</title>
  <style>
    body { font-family: -apple-system, system-ui, sans-serif; padding: 3rem; background: #0f172a; color: #f8fafc; line-height: 1.6; }
    .card { background: #1e293b; padding: 2rem; border-radius: 16px; border: 1px solid #334155; margin-bottom: 2rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .key { color: #94a3b8; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem; }
    .val { color: #fbbf24; font-size: 1.25rem; font-weight: 700; font-family: monospace; }
    h1 { margin-bottom: 1.5rem; color: #fff; font-size: 1.5rem; }
    .badge { padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; background: #334155; margin-left: 8px; }
  </style>
</head>
<body>
  <h1>Status de Autenticação do Admin</h1>
  
  <div class="card">
    <span class="key">Valor Gravado no .env (ADMIN_TOKEN):</span>
    <span class="val">{ENV_TOKEN}</span>
  </div>

  <div class="card">
    <span class="key">Senha Atual que o Servidor espera:</span>
    <span class="val" style="color: #4ade80;">{finalToken}</span>
    <span class="badge">Use esta senha no Login!</span>
  </div>

  <p style="color: #64748b; font-size: 0.85rem;">
    💡 Se a senha esperada estiver errada, certifique-se de que reiniciou o servidor após salvar o .env.
  </p>

  <a href="/admin/login" style="display: inline-block; margin-top: 2rem; color: #38bdf8; text-decoration: none; border: 1px solid #334155; padding: 10px 20px; border-radius: 8px;">
    ← Voltar para a Tela de Login
  </a>
</body>
</html>
