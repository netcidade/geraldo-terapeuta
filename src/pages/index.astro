---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDatabases, getEnvIds, withTimeout, Query } from "../lib/appwrite";
import localProducts from "../content/products.json";

export const prerender = false;

const env = Astro.locals;
const { DB_ID, COL_CONTENT, COL_PRODUCTS, COL_TESTIMONIALS } = getEnvIds(env);
const db = getDatabases(env);

// Busca especialidades do Appwrite
let products = [];
try {
  const res = await withTimeout(
    db.listDocuments(DB_ID, COL_PRODUCTS, [Query.limit(100)]),
    2000,
  );
  products = res.documents.map((d: any) => ({
    ...JSON.parse(d.data.replace(/&nbsp;/g, " ").replace(/\u00A0/g, " ")),
    id: d.$id,
  }));
} catch (e) {
  console.warn("Erro ao buscar especialidades no Appwrite, usando fallback...");
  products = localProducts;
}

// Busca depoimentos do Appwrite
let testimonials = [];
try {
  const res = await withTimeout(
    db.listDocuments(DB_ID, COL_TESTIMONIALS, [
      Query.limit(20),
      Query.orderDesc("$createdAt"),
    ]),
    2000,
  );
  testimonials = res.documents.map((d) => {
    const { $id, ...rest } = d;
    return { ...rest, id: $id };
  });
} catch (e) {
  console.warn("Erro ao buscar depoimentos no Appwrite.");
}

// Busca conteúdo da Home do Appwrite
let homeData: any = {};
let contactData: any = {};
let qsData: any = {};
try {
  const pagesRes = await withTimeout(
    db.listDocuments(DB_ID, COL_CONTENT, [Query.equal("key", "pages")]),
    2000,
  );
  if (pagesRes.documents.length > 0) {
    // Limpeza de non-breaking spaces que causam palavras gigante no layout
    const rawData = pagesRes.documents[0].data
      .replace(/&nbsp;/g, " ")
      .replace(/\u00A0/g, " ");
    const fullContent = JSON.parse(rawData);
    homeData = fullContent.home || {};
    qsData = fullContent.quemsomos || {};
  }

  // Busca dados de contato
  const contactRes = await withTimeout(
    db.listDocuments(DB_ID, COL_CONTENT, [Query.equal("key", "contato")]),
    2000,
  );
  if (contactRes.documents.length > 0) {
    const rawContact = contactRes.documents[0].data
      .replace(/&nbsp;/g, " ")
      .replace(/\u00A0/g, " ");
    contactData = JSON.parse(rawContact);
  }
} catch (e) {
  console.warn("Erro ao buscar conteúdo da home/contato no Appwrite.");
}

const whatsappGlobal = contactData.whatsapp || "5543988728924";

const quemsomos = {
  metrics: qsData.metrics || [
    { value: "20+", label: "Anos de Prática" },
    { value: "1.2k+", label: "Vidas Impactadas" },
  ],
};

const home = {
  seo: homeData.seo || {
    title: "Geraldo Luiz — Terapeuta de Casal e Família",
    description:
      "Especialista em apoio a casais e famílias em Londrina/PR e Online.",
  },
  products_title:
    homeData.site_content?.products_title ||
    'Como posso <span class="text-geraldo-primary">Ajudar?</span>',
  products_subtitle:
    homeData.site_content?.products_subtitle ||
    "Abordagens terapêuticas especializadas e humanizadas para cada fase do seu relacionamento.",
  diferenciais_title:
    homeData.site_content?.diferenciais_title ||
    'Por que escolher a <span class="text-geraldo-primary">Terapia?</span>',
  cta_final: homeData.site_content?.cta_final || {
    headline:
      'Transforme seu <br/><span class="text-white">Relacionamento hoje</span>',
    subheadline:
      "Dê o primeiro passo para uma conexão mais profunda e saudável.",
  },
};

// Fallback seguro usando estruturação para não perder os defaults caso existam apenas campos parciais
const heroData = homeData.hero || {};
const hero = {
  headline:
    heroData.headline ||
    'Reencontre o <span class="text-geraldo-primary italic">Equilíbrio</span> na sua relação.',
  subheadline:
    heroData.subheadline ||
    "Apoiando casais e famílias a cultivarem conexões mais profundas, superarem conflitos e construírem um futuro com base no diálogo e respeito mútuo.",
  cta_primary_text: heroData.cta_primary_text || "Agendar Consulta",
  cta_primary_url:
    heroData.cta_primary_url ||
    `https://api.whatsapp.com/send?phone=${whatsappGlobal}`,
  cta_secondary_text: heroData.cta_secondary_text || "Conhecer Serviços",
  cta_secondary_url: heroData.cta_secondary_url || "#servicos",
  image: heroData.image || "/img/foto-GERALDO-2.jpg",
};

const diferenciais = homeData.site_content?.diferenciais || [
  {
    icon: "Shield",
    title: "20+ Anos",
    desc: "Vasta experiência no atendimento clínico.",
  },
  {
    icon: "Heart",
    title: "Acolhimento",
    desc: "Atendimento humanizado e sem julgamentos.",
  },
  {
    icon: "Zap",
    title: "Foco Familiar",
    desc: "Especialização em dinâmicas familiares complexas.",
  },
  {
    icon: "GraduationCap",
    title: "Sólida Formação",
    desc: "Membro da APRTF e ABRATEF.",
  },
  {
    icon: "Clock",
    title: "Online/Presencial",
    desc: "Flexibilidade para atender você onde estiver.",
  },
];

// Mapeamento de Ícones (SVG Paths)
const IconMap: Record<string, string> = {
  Heart:
    '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>',
  Shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>',
  Star: '<path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
  Users:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  GraduationCap:
    '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>',
  Award:
    '<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>',
  Zap: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>',
  Stethoscope:
    '<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/>',
  CreditCard:
    '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>',
  Clock:
    '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  Infinity:
    '<path d="M12 12c-2-2.67-4-4-6-4a4 4 0 1 0 0 8c2 0 4-1.33 6-4Zm0 0c2 2.67 4 4 6 4a4 4 0 0 0 0-8c-2 0-4 1.33-6 4Z"/>',
  ShieldCheck:
    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/>',
  Cpu: '<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="15" x2="23" y2="15"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="15" x2="4" y2="15"/>',
  Printer:
    '<polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>',
};

const serviceImages = [
  "/img/terapia-casais2_600x450.jpg",
  "/img/namorados-noivos2_600x450.jpg",
  "/img/recem-casados2_600x450.jpg",
  "/img/casal-com-filhos2_600x450.jpg",
  "/img/vidamadura2_600x450.jpg",
];
---

<BaseLayout title={home.seo?.title} description={home.seo?.description}>
  <!-- ═══════════════════════════════════
       HERO SECTION: PREMIUM ZEN
  ═══════════════════════════════════ -->
  <section
    class="relative min-h-screen flex items-center overflow-hidden pt-32 md:pt-10"
  >
    <!-- Imagem de Fundo com Overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="/img/zen_bg.png"
        class="w-full h-full object-cover opacity-80"
        alt="Consultório Zen"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-geraldo-bg/50 via-geraldo-bg/80 to-geraldo-bg"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 w-full relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Conteúdo Textual -->
        <div
          class="reveal order-1 lg:order-1 flex flex-col items-center lg:items-start text-center lg:text-left"
        >
          <div
            class="inline-flex items-center gap-2 bg-geraldo-primary/10 text-geraldo-primary text-xs font-bold px-4 py-2 rounded-full mb-8 uppercase tracking-widest border border-geraldo-primary/20"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-geraldo-primary opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-geraldo-primary"
              ></span>
            </span>
            Atendimento Humanizado & Especializado
          </div>

          <h1
            class="font-heading text-5xl md:text-6xl lg:text-7xl text-geraldo-dark font-bold leading-[1.1] mb-5"
            set:html={hero.headline}
          />
          <p
            class="text-xl text-gray-600 leading-relaxed max-w-lg font-light"
            set:html={hero.subheadline}
          />

          <div
            class="flex flex-col sm:flex-row gap-4 mt-5 w-full justify-center lg:justify-start"
          >
            <a href={hero.cta_primary_url} target="_blank" class="btn-primary">
              {hero.cta_primary_text}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                  points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
              >
            </a>
            {
              hero.cta_secondary_text &&
                hero.cta_secondary_text.trim() !== "" && (
                  <a
                    href={hero.cta_secondary_url || "#servicos"}
                    class="btn-secondary"
                  >
                    {hero.cta_secondary_text}
                  </a>
                )
            }
          </div>

          <!-- Métricas (20+ e 1.2k) abaixo dos botões -->
          <div
            class="mt-12 flex gap-10 items-center justify-center lg:justify-start"
          >
            <div class="flex flex-col items-center lg:items-start">
              <p
                class="text-3xl font-heading font-bold text-geraldo-dark leading-none"
              >
                {quemsomos.metrics[0]?.value || "20+"}
              </p>
              <p
                class="text-[11px] text-gray-500 font-bold uppercase tracking-widest mt-2"
              >
                {quemsomos.metrics[0]?.label || "Anos de Prática"}
              </p>
            </div>
            <div class="w-px h-10 bg-geraldo-primary/20"></div>
            <div class="flex flex-col items-center lg:items-start">
              <p
                class="text-3xl font-heading font-bold text-geraldo-dark leading-none"
              >
                {quemsomos.metrics[1]?.value || "1.2k+"}
              </p>
              <p
                class="text-[11px] text-gray-400 font-bold uppercase tracking-widest mt-2"
              >
                {quemsomos.metrics[1]?.label || "Vidas Impactadas"}
              </p>
            </div>
          </div>
        </div>

        <!-- Elemento Visual: Foto Estilo Bio -->
        <div
          class="relative flex justify-center lg:justify-start reveal mt-12 lg:mt-0"
          style="animation-delay: 0.3s"
        >
          <div
            class="absolute inset-x-0 bottom-0 h-2/3 bg-geraldo-primary/10 rounded-[3rem] blur-3xl"
          >
          </div>
          <div
            class="relative bg-white p-5 rounded-[4rem] shadow-2xl border border-white backdrop-blur-sm overflow-hidden group w-fit"
          >
            <img
              src={hero.image}
              alt="Geraldo Luiz - Terapeuta"
              class="w-full max-w-md h-[350px] lg:h-[550px] object-cover rounded-[3.5rem] grayscale-[15%] group-hover:grayscale-0 transition-all duration-700"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-geraldo-dark/30 to-transparent"
            >
            </div>
            <!-- Badge Nome (Restaurado) -->
            <div
              class="absolute bottom-6 left-6 sm:bottom-8 sm:left-8 bg-white/95 backdrop-blur-lg px-6 py-3 sm:px-8 sm:py-4 rounded-2xl shadow-xl border border-geraldo-soft/50 group-hover:left-10 transition-all duration-500"
            >
              <p
                class="text-geraldo-dark font-heading font-bold text-lg leading-tight"
              >
                Geraldo Luiz
              </p>
              <p
                class="text-geraldo-primary text-[10px] font-bold uppercase tracking-widest mt-0.5"
              >
                Terapeuta Sistêmico
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       DIFERENCIAIS: VALORES RECONHECIDOS
  ═══════════════════════════════════ -->
  <section class="py-20 bg-geraldo-bg/30">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <h2 class="section-title mb-6" set:html={home.diferenciais_title} />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {
          diferenciais.map((item, i) => (
            <div
              class="bg-white p-8 rounded-[2.5rem] border border-geraldo-soft/30 shadow-sm hover:shadow-xl transition-all duration-500 reveal group"
              style={`animation-delay: ${i * 100}ms`}
            >
              <div class="w-12 h-12 bg-geraldo-bg rounded-xl flex items-center justify-center text-geraldo-primary mb-6 group-hover:scale-110 group-hover:bg-geraldo-primary group-hover:text-white transition-all duration-500">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={IconMap[item.icon] || IconMap.Zap}
                />
              </div>
              <h3 class="font-bold text-geraldo-dark mb-2">{item.title}</h3>
              <p class="text-sm text-gray-500 font-light leading-relaxed">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       ESPECIALIDADES GRID
  ═══════════════════════════════════ -->
  <section id="servicos" class="pt-20 pb-14 bg-white relative overflow-hidden">
    <!-- Abstract Shape -->
    <div
      class="absolute -left-20 top-1/4 w-96 h-96 bg-geraldo-accent/10 rounded-full blur-3xl"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between mb-20 reveal"
      >
        <div class="max-w-2xl">
          <h2 class="section-title mb-6" set:html={home.products_title} />
          <p
            class="text-xl text-gray-500 font-light leading-relaxed"
            set:html={home.products_subtitle}
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          products.map((product, i) => (
            <a
              href={`/especialidades/${product.slug}`}
              class="card-zen group reveal flex flex-col h-full"
              style={`animation-delay: ${i * 100}ms`}
            >
              <div class="relative h-64 overflow-hidden rounded-[1.5rem] mb-8 shadow-sm">
                <img
                  src={product.image || serviceImages[i % serviceImages.length]}
                  alt={product.title || product.name}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-geraldo-dark/60 to-transparent flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity">
                  <span class="text-white text-sm font-medium">
                    Conhecer detalhes
                  </span>
                </div>
              </div>
              <div class="flex flex-col flex-grow">
                <h3 class="font-heading font-bold text-2xl text-geraldo-dark mb-4">
                  {product.title || product.name}
                </h3>
                <p class="text-gray-500 font-light leading-relaxed mb-8 flex-grow">
                  {product.excerpt ||
                    product.desc ||
                    product.headline?.replace(/<[^>]*>?/gm, "") ||
                    "Clique para saber mais sobre este atendimento especializado."}
                </p>
                <div class="flex items-center gap-2 text-geraldo-primary font-bold group-hover:gap-4 transition-all mt-auto">
                  <span>Saiba Mais</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </>
                  </svg>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       DEPOIMENTOS: CLEAN MASONRY
  ═══════════════════════════════════ -->
  <section class="pt-16 pb-6 bg-geraldo-soft/30 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <h2 class="section-title mb-6" set:html={home.diferenciais_title} />
        <div class="flex items-center justify-center gap-1">
          {
            Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 fill-geraldo-primary" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))
          }
          <span class="ml-2 font-bold text-geraldo-dark">Excelente 4.9/5</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          testimonials.map((r: any) => (
            <div class="bg-white rounded-3xl p-10 border border-white shadow-sm hover:shadow-xl transition-all duration-500 reveal group">
              <div class="flex justify-between items-start mb-6">
                <div class="text-geraldo-primary opacity-30 group-hover:opacity-100 transition-opacity">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C14.9124 8 14.017 7.10457 14.017 6V3H21.017C22.1216 3 23.017 3.89543 23.017 5V15C23.017 18.3137 20.3307 21 17.017 21H14.017ZM1.017 21L1.017 18C1.017 16.8954 1.91243 16 3.017 16H6.017C6.56928 16 7.017 15.5523 7.017 15V9C7.017 8.44772 6.56928 8 6.017 8H3.017C1.91243 8 1.017 7.10457 1.017 6V3H8.017C9.12157 3 10.017 3.89543 10.017 5V15C10.017 18.3137 7.33071 21 4.017 21H1.017Z" />
                  </svg>
                </div>
                <div class="flex gap-0.5">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg
                      class={`w-4 h-4 ${i < (r.stars || 5) ? "text-yellow-400 fill-yellow-400" : "text-gray-200 fill-gray-200"}`}
                      viewBox="0 0 20 20"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <p class="text-gray-600 text-lg leading-relaxed mb-8 font-light italic">
                "{r.text}"
              </p>
              <div class="flex items-center gap-4">
                {r.image_url ? (
                  <img
                    src={r.image_url}
                    alt={r.name}
                    class="w-12 h-12 rounded-full object-cover border-2 border-geraldo-accent"
                  />
                ) : (
