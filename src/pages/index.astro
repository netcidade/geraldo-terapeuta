---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDatabases, getEnvIds, withTimeout } from "../lib/appwrite";
import { Query } from "node-appwrite";
import localProducts from "../content/products.json";

export const prerender = false;

const env = (Astro.locals as any).runtime?.env ?? {};
const { DB_ID, COL_PRODUCTS } = getEnvIds(env);
const db = getDatabases(env);

// Busca especialidades do Appwrite
let products = [];
try {
  const res = await withTimeout(db.listDocuments(DB_ID, COL_PRODUCTS, [Query.limit(100)]), 1500);
  products = res.documents.map((d: any) => JSON.parse(d.data));
} catch (e) {
  console.warn("Erro ao buscar especialidades no Appwrite, usando fallback...");
  // Fallback para não quebrar a home
  products = localProducts;
}

const home = {
  seo: {
    title: "Geraldo Luiz — Terapeuta de Casal e Família",
    description:
      "Especialista em apoio a casais e famílias em Londrina/PR e Online.",
  },
  products_title:
    'Como posso <span class="text-geraldo-primary">Ajudar?</span>',
  products_subtitle:
    "Abordagens terapêuticas especializadas para cada fase do seu relacionamento.",
  diferenciais_title:
    'Por que escolher a <span class="text-geraldo-primary">Terapia?</span>',
  cta_final: {
    headline:
      'Transforme seu <br/><span class="text-white">Relacionamento hoje</span>',
    subheadline:
      "Dê o primeiro passo para uma conexão mais profunda e saudável.",
  },
};
const hero = {
  cta_primary_text: "Agendar Consulta",
  cta_primary_url: "https://api.whatsapp.com/send?phone=5543988728924",
  cta_secondary_text: "Conhecer Serviços",
  cta_secondary_url: "#servicos",
};
const diferenciais = [
  {
    icon: "ShieldCheck",
    title: "20+ Anos",
    desc: "Vasta experiência no atendimento clínico.",
  },
  {
    icon: "Infinity",
    title: "Acolhimento",
    desc: "Atendimento humanizado e sem julgamentos.",
  },
  {
    icon: "Zap",
    title: "Foco Familiar",
    desc: "Especialização em dinâmicas familiares complexas.",
  },
  {
    icon: "Printer",
    title: "Sólida Formação",
    desc: "Membro da APRTF e ABRATEF.",
  },
  {
    icon: "Cpu",
    title: "Online/Presencial",
    desc: "Flexibilidade para atender você onde estiver.",
  },
];

const serviceImages = [
  "/img/terapia-casais2_600x450.jpg",
  "/img/namorados-noivos2_600x450.jpg",
  "/img/recem-casados2_600x450.jpg",
  "/img/casal-com-filhos2_600x450.jpg",
  "/img/vidamadura2_600x450.jpg",
];
---

<BaseLayout title={home.seo?.title} description={home.seo?.description}>
  <!-- ═══════════════════════════════════
       HERO SECTION: PREMIUM ZEN
  ═══════════════════════════════════ -->
  <section
    class="relative min-h-screen flex items-center overflow-hidden pt-10"
  >
    <!-- Imagem de Fundo com Overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="/img/zen_bg.png"
        class="w-full h-full object-cover opacity-80"
        alt="Consultório Zen"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-geraldo-bg/50 via-geraldo-bg/80 to-geraldo-bg"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 w-full relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Conteúdo Textual -->
        <div class="reveal order-2 lg:order-1">
          <div
            class="inline-flex items-center gap-2 bg-geraldo-primary/10 text-geraldo-primary text-xs font-bold px-4 py-2 rounded-full mb-8 uppercase tracking-widest border border-geraldo-primary/20"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-geraldo-primary opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-geraldo-primary"
              ></span>
            </span>
            Atendimento Humanizado & Especializado
          </div>

          <h1
            class="font-heading text-5xl md:text-6xl lg:text-7xl text-geraldo-dark font-bold leading-[1.1] mb-8"
          >
            Reencontre o <span class="text-geraldo-primary italic"
              >Equilíbrio</span
            > na sua relação.
          </h1>
          <p
            class="text-xl text-gray-600 leading-relaxed mb-10 max-w-lg font-light"
          >
            Apoiando casais e famílias a cultivarem conexões mais profundas,
            superarem conflitos e construírem um futuro com base no diálogo e
            respeito mútuo.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href={hero.cta_primary_url} target="_blank" class="btn-primary">
              {hero.cta_primary_text}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                  points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
              >
            </a>
            <a href={hero.cta_secondary_url} class="btn-secondary">
              {hero.cta_secondary_text}
            </a>
          </div>
        </div>

        <!-- Elemento Visual: Glass Card (A Face do Profissional: Geraldo Luiz) -->
        <div
          class="relative reveal order-1 lg:order-2 mt-[100px] lg:mt-0"
          style="animation-delay: 0.3s"
        >
          <div class="relative group">
            <!-- Glow Effect -->
            <div
              class="absolute inset-0 bg-geraldo-primary/20 rounded-[3.5rem] blur-3xl group-hover:bg-geraldo-primary/30 transition-all duration-700"
            >
            </div>

            <div
              class="relative bg-white p-4 lg:p-5 rounded-[3.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.1)] border border-white/60 backdrop-blur-sm overflow-hidden"
            >
              <div
                class="relative h-[250px] sm:h-[450px] lg:h-[650px] w-full overflow-hidden rounded-[2.8rem]"
              >
                <img
                  src="/img/foto-GERALDO-2.jpg"
                  alt="Geraldo Luiz - Terapeuta"
                  class="w-full h-full object-cover object-top lg:object-center grayscale-[19%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000"
                />

                <!-- Overlay de Gradiente -->
                <div
                  class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-geraldo-dark/40 to-transparent"
                >
                </div>
              </div>

              <!-- Badge Profissional (Nome) -->
              <div
                class="absolute -bottom-1 left-5 bg-white/95 backdrop-blur-lg px-10 py-5 hidden sm:block rounded-2xl shadow-2xl border border-geraldo-soft/50 group-hover:left-12 transition-all duration-500"
              >
                <p
                  class="text-geraldo-dark font-heading font-bold text-xl leading-tight"
                >
                  Geraldo Luiz
                </p>
                <p
                  class="text-geraldo-primary text-xs font-bold uppercase tracking-widest mt-1"
                >
                  Terapeuta Sistêmico
                </p>
              </div>

              <!-- Badge de Stats (Lado Oposto ao Nome na Parte Inferior) -->
              <div
                class="absolute -bottom-1 right-5 bg-white/95 backdrop-blur-lg px-8 py-5 rounded-2xl shadow-2xl border border-geraldo-soft/50"
              >
                <div class="flex gap-6 items-center">
                  <div class="text-center">
                    <p
                      class="text-2xl font-heading font-bold text-geraldo-dark leading-none"
                    >
                      20+
                    </p>
                    <p
                      class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter mt-1"
                    >
                      Anos de Prática
                    </p>
                  </div>
                  <div class="w-px h-8 bg-geraldo-soft/50"></div>
                  <div class="text-center">
                    <p
                      class="text-2xl font-heading font-bold text-geraldo-dark leading-none"
                    >
                      1.2k+
                    </p>
                    <p
                      class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter mt-1"
                    >
                      Vidas Impactadas
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       ESPECIALIDADES GRID
  ═══════════════════════════════════ -->
  <section id="servicos" class="pt-0 pb-14 bg-white relative overflow-hidden">
    <!-- Abstract Shape -->
    <div
      class="absolute -left-20 top-1/4 w-96 h-96 bg-geraldo-accent/10 rounded-full blur-3xl"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between mb-20 reveal"
      >
        <div class="max-w-2xl">
          <h2 class="section-title mb-6">
            Como posso caminhar <br /><span class="italic text-geraldo-primary"
              >ao seu lado?</span
            >
          </h2>
          <p class="text-xl text-gray-500 font-light leading-relaxed">
            Através de uma escuta acolhedora, trabalhamos as bases do
            relacionamento para que o amor floresça com maturidade e respeito.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          products.map((product, i) => (
            <a
              href={`/especialidades/${product.slug}`}
              class="card-zen group reveal flex flex-col h-full"
              style={`animation-delay: ${i * 100}ms`}
            >
              <div class="relative h-64 overflow-hidden rounded-[1.5rem] mb-8 shadow-sm">
                <img
                  src={product.image || serviceImages[i % serviceImages.length]}
                  alt={product.title || product.name}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-geraldo-dark/60 to-transparent flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity">
                  <span class="text-white text-sm font-medium">
                    Conhecer detalhes
                  </span>
                </div>
              </div>
              <div class="flex flex-col flex-grow">
                <h3 class="font-heading font-bold text-2xl text-geraldo-dark mb-4">
                  {product.title || product.name}
                </h3>
                <p class="text-gray-500 font-light leading-relaxed mb-8 flex-grow">
                  {product.excerpt || product.desc || product.headline?.replace(/<[^>]*>?/gm, '') || "Clique para saber mais sobre este atendimento especializado."}
                </p>
                <div class="flex items-center gap-2 text-geraldo-primary font-bold group-hover:gap-4 transition-all mt-auto">
                  <span>Saiba Mais</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </>
                  </svg>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       DEPOIMENTOS: CLEAN MASONRY
  ═══════════════════════════════════ -->
  <section class="py-12 bg-geraldo-soft/30 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-24 reveal">
        <h2 class="section-title mb-6">
          Histórias que <br /><span class="text-geraldo-primary italic"
            >Se Transformaram</span
          >
        </h2>
        <div class="flex items-center justify-center gap-1">
          {
            Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 fill-geraldo-primary" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))
          }
          <span class="ml-2 font-bold text-geraldo-dark">Excelente 4.9/5</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          [
            {
              name: "Ana Souza",
              text: "O Geraldo é um profissional incrível. A terapia mudou nossa forma de conviver em família. Hoje temos mais empatia e menos conflitos.",
              role: "Terapia Familiar",
            },
            {
              name: "Marcos e Julia",
              text: "Estávamos perdidos e a terapia de casal foi o nosso porto seguro. Aprendemos a conversar de verdade, sem mágoas.",
              role: "Terapia de Casal",
            },
            {
              name: "Ricardo L.",
              text: "A visão sistêmica do Geraldo me ajudou em todas as áreas da vida. Um atendimento humano e muito competente.",
              role: "Atendimento Individual",
            },
          ].map((r, i) => (
            <div class="bg-white rounded-3xl p-10 border border-white shadow-sm hover:shadow-xl transition-all duration-500 reveal group">
              <div class="text-geraldo-primary mb-6 opacity-30 group-hover:opacity-100 transition-opacity">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C14.9124 8 14.017 7.10457 14.017 6V3H21.017C22.1216 3 23.017 3.89543 23.017 5V15C23.017 18.3137 20.3307 21 17.017 21H14.017ZM1.017 21L1.017 18C1.017 16.8954 1.91243 16 3.017 16H6.017C6.56928 16 7.017 15.5523 7.017 15V9C7.017 8.44772 6.56928 8 6.017 8H3.017C1.91243 8 1.017 7.10457 1.017 6V3H8.017C9.12157 3 10.017 3.89543 10.017 5V15C10.017 18.3137 7.33071 21 4.017 21H1.017Z" />
                </svg>
              </div>
              <p class="text-gray-600 text-lg leading-relaxed mb-8 font-light italic">
                "{r.text}"
              </p>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-geraldo-accent flex items-center justify-center font-bold text-geraldo-primary">
                  {r.name[0]}
                </div>
                <div>
                  <div class="font-bold text-geraldo-dark">{r.name}</div>
                  <div class="text-xs text-gray-400 font-medium uppercase tracking-wider">
                    {r.role}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       CTA FINAL: PREMIUM FOOTER
  ═══════════════════════════════════ -->
  <section class="py-32 relative bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div
        class="bg-geraldo-dark rounded-[3rem] p-12 md:p-24 overflow-hidden relative shadow-2xl"
      >
        <!-- Abstract Glow -->
        <div
          class="absolute -right-20 -bottom-20 w-80 h-80 bg-geraldo-primary/20 rounded-full blur-3xl"
        >
        </div>

        <div class="relative z-10 max-w-2xl text-center md:text-left">
          <h2
            class="font-heading text-4xl md:text-6xl text-white font-bold mb-8 leading-tight"
          >
            Pronto para dar o <br />
            <span class="text-geraldo-primary italic">próximo passo?</span>
          </h2>
          <p class="text-xl text-gray-400 mb-12 font-light">
            Uma vida mais plena e relacionamentos mais saudáveis começam com uma
            única conversa.
          </p>
          <a
            href="https://api.whatsapp.com/send?phone=5543988728924"
            target="_blank"
            class="bg-white text-geraldo-dark font-bold text-xl px-12 py-5 rounded-full
                   hover:bg-geraldo-primary hover:text-white transition-all duration-300 inline-flex items-center gap-3"
          >
            Atendimento via WhatsApp
            <svg
              class="w-6 h-6 shadow-sm"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
