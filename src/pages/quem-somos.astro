---
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../content/pages.json';
export const prerender = false;
const { quemsomos, contato } = content;
---

<BaseLayout
  title={quemsomos.seo?.title}
  description={quemsomos.seo?.description}
>
  <!-- Hero -->
  <section class="bg-geraldo-dark pt-32 pb-20 relative overflow-hidden">
    <div class="particles-bg">
      {Array.from({length:12}).map((_, i) => (
        <div class="particle-dot" style={`width:${4+(i%4)*2}px;height:${4+(i%4)*2}px;background:${i%2===0?'#f5a623':'#2d6bc4'};opacity:${0.25+(i%3)*0.15};left:${(i*17+3)%94}%;top:${(i*29+5)%85}%;--dur:${2.8+(i%4)*0.6}s;--delay:${(i*0.3)%2.2}s`}/>
      ))}
    </div>
    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-geraldo-primary/40 border border-geraldo-accent/30
                  text-geraldo-accent text-xs font-semibold px-4 py-1.5 rounded-full mb-6 animate-fade-in">
        <span class="w-1.5 h-1.5 bg-geraldo-secondary rounded-full"></span>
        Fundada em 1999 — Londrina/PR
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl text-white font-bold mb-6 animate-slide-up"
          set:html={quemsomos.hero_headline}/>
      <p class="text-geraldo-accent text-xl animate-slide-up" style="animation-delay:0.15s"
         set:html={quemsomos.hero_sub}/>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 50" fill="none"><path d="M0 50L1440 50L1440 15C1200 50 960 0 720 15C480 30 240 0 0 15L0 50Z" fill="#ffffff"/></svg>
    </div>
  </section>

  <!-- Métricas -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {quemsomos.metrics.map((m: any, i: number) => (
          <div class="text-center reveal" style={`animation-delay:${i*100}ms`}>
            <div class="font-heading text-4xl font-bold text-geraldo-primary mb-2">{m.value}</div>
            <div class="text-gray-500 text-sm">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sobre -->
  <section class="py-20 bg-geraldo-bg">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="reveal">
          <h2 class="section-title mb-6">Nossa história</h2>
          <div class="rich-content text-gray-600" set:html={quemsomos.about_text}/>
          <div class="flex gap-4 mt-8">
            <a href="https://api.whatsapp.com/send?phone=${contato.whatsapp}" target="_blank" class="btn-primary">
              Fale conosco
            </a>
          </div>
        </div>
        <div class="flex justify-center reveal">
          <div class="animate-float">
            <img src="https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png"
             alt="Geraldo Terapeuta" class="w-72 drop-shadow-xl"/>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="section-title text-center mb-12 reveal">Nossos valores</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { emoji:'🏆', title:'Qualidade', desc:'Matéria prima selecionada e processos controlados do início ao fim da produção.' },
          { emoji:'💡', title:'Inovação', desc:'Tecnologias de identificação modernas — RFID, QR Code, biometria e muito mais.' },
          { emoji:'🤝', title:'Atendimento', desc:'Equipe dedicada e atendimento descomplicado. Seu pedido é prioridade.' },
        ].map((v, i) => (
          <div class="bg-geraldo-bg rounded-2xl p-7 text-center reveal" style={`animation-delay:${i*100}ms`}>
            <div class="text-4xl mb-4">{v.emoji}</div>
            <h3 class="font-heading font-bold text-geraldo-primary text-lg mb-3">{v.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Localização -->
  <section class="py-16 bg-geraldo-bg">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="section-title text-center mb-10 reveal">Onde estamos</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="reveal space-y-4">
          <div class="flex items-start gap-3">
            <span class="text-2xl">📍</span>
            <div>
              <div class="font-semibold text-geraldo-text">Endereço</div>
              <div class="text-gray-500 text-sm">{contato.endereco}</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl">📞</span>
            <div>
              <div class="font-semibold text-geraldo-text">Telefones</div>
              <a href={`tel:${contato.whatsapp}`} class="text-geraldo-primary text-sm block hover:underline">{contato.whatsapp}</a>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl">💬</span>
            <div>
              <div class="font-semibold text-geraldo-text">WhatsApp</div>
              <a href={`https://api.whatsapp.com/send?phone=${contato.whatsapp}`} target="_blank"
                 class="text-green-600 text-sm hover:underline">{contato.whatsapp}</a>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl">✉️</span>
            <div>
              <div class="font-semibold text-geraldo-text">E-mail</div>
              <a href="mailto:contato@geraldoterapeuta.com.br" class="text-geraldo-primary text-sm hover:underline">
                contato@geraldoterapeuta.com.br
              </a>
            </div>
          </div>
        </div>
        <div class="reveal rounded-2xl overflow-hidden shadow-lg h-64 bg-gray-100 flex items-center justify-center">
           <div class="text-center p-6">
             <span class="text-4xl mb-2 block">📍</span>
             <div class="text-sm text-gray-500">{contato.endereco}</div>
           </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
